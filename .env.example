# Copy this file to ".env" and fill in what you have.
# VendorAI runs even with NOTHING filled in (uses a rule-based fallback extractor).

# --- LLM provider ---
# "auto" picks OpenAI if OPENAI_API_KEY is set, else Grok if GROK_API_KEY is set,
# else falls back to the built-in rule-based extractor.
LLM_PROVIDER=auto

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GROK_API_KEY=
GROK_MODEL=grok-2-latest
GROK_BASE_URL=https://api.x.ai/v1

# --- Optional: LangSmith tracing (great for your project report/demo) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=vendorai

# --- App ---
DB_PATH=data/vendorai.db
DEFAULT_LANGUAGE=en
LOW_STOCK_THRESHOLD_DEFAULT=5

# URL where the FastAPI backend runs (used by the Streamlit frontend)
BACKEND_URL=http://127.0.0.1:8000
